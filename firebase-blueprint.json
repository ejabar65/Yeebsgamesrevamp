{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "favoriteGameIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "username", "password"]
    },
    "Game": {
      "title": "Game Meta",
      "description": "Metadata for unblocked games",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "playCount": { "type": "number" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url", "category"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Games metadata"
    }
  }
}
