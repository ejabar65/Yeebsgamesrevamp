{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "favoriteGameIds": { "type": "array" },
        "history": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isBanned": { "type": "boolean" },
        "avatarConfig": { "type": "object" },
        "settings": { "type": "object" }
      },
      "required": ["uid", "username", "password"]
    },
    "Chat": {
      "title": "Chat",
      "description": "DM Chat session",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "A public post in the community",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "gameId": { "type": "string" },
        "gameTitle": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "array" },
        "replies": { "type": "array" }
      }
    }
  },
  "firestore": {
    "users/{username}": {
      "schema": "User",
      "description": "User profiles indexed by lowercase username"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "DM sessions"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Public community posts"
    }
  }
}
