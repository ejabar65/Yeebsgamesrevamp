{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "photoURL": { "type": "string" },
        "isBanned": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "settings": {
          "type": "object",
          "properties": {
            "compactMode": { "type": "boolean" },
            "showChatPreview": { "type": "boolean" },
            "customTheme": { "type": "string" }
          }
        },
        "history": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "favoriteGameIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "username", "password"]
    },
    "Game": {
      "title": "Game Meta",
      "description": "Metadata for unblocked games",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "playCount": { "type": "number" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url", "category"]
    },
    "GlobalMessage": {
      "title": "Global Chat Message",
      "description": "A message in the public chatroom",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "createdAt"]
    },
    "ChatSession": {
      "title": "DM Session",
      "description": "A private chat session between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "DirectMessage": {
      "title": "Private Message",
      "description": "A 1-on-1 private message",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/global_messages/{messageId}": {
      "schema": "GlobalMessage",
      "description": "Public messages"
    },
    "/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Private chat headers"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "DirectMessage",
      "description": "Private message content"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Games metadata"
    }
  }
}
