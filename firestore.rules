rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      // We allow guest access because our custom password logic gates the collections
      return true;
    }

    // Check if the current user has admin status by checking the master 'yeebs' account
    function isAdmin() {
      // In this no-auth architecture, we check if either 'yeebs' or 'Yeebs' exists
      // and has the master password.
      return (exists(/databases/$(database)/documents/users/yeebs) && 
              get(/databases/$(database)/documents/users/yeebs).data.password == '$#GS29gs1') ||
             (exists(/databases/$(database)/documents/users/Yeebs) && 
              get(/databases/$(database)/documents/users/Yeebs).data.password == '$#GS29gs1');
    }

    function isPasswordOwner(username) {
      // If document exists, the submitted password must match the stored one
      return (!exists(/databases/$(database)/documents/users/$(username))) || 
             (get(/databases/$(database)/documents/users/$(username)).data.password == incoming().password);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUserCreate(data) {
      return data.keys().hasAll(['uid', 'username', 'password']) &&
             data.uid is string &&
             data.username is string && data.username.size() <= 50 &&
             data.password is string && data.password.size() <= 100 &&
             (data.get('isBanned', false) is bool) &&
             (data.get('isAdmin', false) is bool) &&
             (data.get('favoriteGameIds', []) is list);
    }

    function isValidUserUpdate(data) {
      // For updates, we check that if a field is present, it's the right type
      return (data.get('uid', 'uid') is string) &&
             (data.get('username', 'user') is string) &&
             (data.get('bio', '') is string) && data.get('bio', '').size() <= 1000 &&
             (data.get('isBanned', false) is bool) &&
             (data.get('isAdmin', false) is bool) &&
             (data.get('avatarConfig', {}) is map) &&
             (data.get('favoriteGameIds', []) is list) &&
             (data.get('settings', {}) is map) &&
             (data.get('tabs', []) is list) &&
             (data.get('history', []) is list);
    }

    function isValidGlobalMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'createdAt']) &&
             data.text is string && data.text.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidDirectMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'createdAt']) &&
             data.text is string && data.text.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidChatSession(data) {
      return data.keys().hasAll(['participants', 'updatedAt']) &&
             data.participants is list && data.participants.size() == 2 &&
             data.updatedAt == request.time;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'category']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 1000 &&
             data.category is string && data.category.size() <= 100 &&
             (data.get('playCount', 0) is number) &&
             (data.get('rating', 0) is number);
    }

    function isValidCustomMovie(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'type']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 1000 &&
             data.type in ['movie', 'tv', 'outside'] &&
             (data.get('description', '') is string) &&
             (data.get('thumbnail', '') is string);
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'ownerId', 'ownerName', 'members', 'settings', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.ownerId is string &&
             data.members is list &&
             data.settings is map &&
             data.settings.keys().hasAll(['spamLimit', 'filterEnabled']) &&
             data.createdAt == request.time;
    }

    function isValidGroupMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'createdAt']) &&
             data.text is string && data.text.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /groups/{groupId} {
      allow get: if true;
      allow list: if true;
      allow create: if isValidGroup(incoming());
      allow update: if isValidGroup(incoming()); // Simplified for this environment's loose auth
      allow delete: if isAdmin() || (existing().ownerId == incoming().ownerId);

      match /messages/{messageId} {
        allow read: if true;
        allow create: if isValidGroupMessage(incoming());
        allow delete: if isAdmin();
      }

      match /voice_participants/{userId} {
        allow read: if true;
        allow write: if true; // Simplified for this environment to allow heartbeat-style management
      }
    }

    match /users/{username} {
      allow get: if true; 
      allow list: if true; 
      allow create: if !exists(/databases/$(database)/documents/users/$(username)) && isValidUserCreate(incoming());
      allow update: if isValidUserUpdate(incoming()) && (
        (isPasswordOwner(username) && incoming().diff(existing()).affectedKeys().hasOnly(['photoURL', 'favoriteGameIds', 'uid', 'lastMessageAt', 'settings', 'history', 'isAdmin', 'bio', 'avatarConfig', 'tabs'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['photoURL', 'favoriteGameIds', 'uid', 'lastMessageAt', 'isBanned', 'isAdmin', 'settings', 'history', 'bio', 'avatarConfig', 'tabs']))
      );
      allow delete: if isAdmin();
    }
    
    match /global_messages/{messageId} {
      allow read: if true;
      allow create: if isValidGlobalMessage(incoming());
      allow update, delete: if isAdmin();
    }

    match /custom_movies/{movieId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCustomMovie(incoming());
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow get: if true;
      allow list: if true;
      allow create: if true;
      allow update: if true;
      
      match /messages/{messageId} {
        allow read: if true;
        allow create: if isValidDirectMessage(incoming());
      }
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGame(incoming());
      allow update: if isAdmin() || (
        isValidGame(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['playCount', 'rating'])
      );
      allow delete: if isAdmin();
    }
  }
}
