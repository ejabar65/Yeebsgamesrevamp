rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the current user IS the admin 'Yeebs'
    function isAdmin() {
      return isSignedIn() && (
        // Yeebs document must exist and have the current user's UID
        exists(/databases/$(database)/documents/users/Yeebs) &&
        get(/databases/$(database)/documents/users/Yeebs).data.uid == request.auth.uid
      );
    }

    function isOwner(username) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(username)) && 
         get(/databases/$(database)/documents/users/$(username)).data.uid == request.auth.uid) ||
        // For creation, if they are claiming it
        (!exists(/databases/$(database)/documents/users/$(username)) && 
         request.resource.data.uid == request.auth.uid)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.username is string && data.username.size() <= 50 &&
             (data.get('favoriteGameIds', []) is list) &&
             data.uid == request.auth.uid;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'category']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 1000 &&
             data.category is string && data.category.size() <= 100 &&
             (data.get('playCount', 0) is number) &&
             (data.get('rating', 0) is number);
    }

    // --- Collections ---

    match /users/{username} {
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/users/$(username)) && isValidUser(incoming());
      allow update: if isSignedIn() && existing().uid == request.auth.uid && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['photoURL', 'favoriteGameIds'])
      );
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGame(incoming());
      allow update: if (isAdmin() && isValidGame(incoming())) || (
        isValidGame(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['playCount', 'rating'])
      );
      allow delete: if isAdmin();
    }
  }
}
